<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_abc_distribution_map" model="ir.ui.view">
        <field name="name">account.move.form.abc.distribution.map</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- árbol de invoice_line_ids -->
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='analytic_distribution']" position="after">
                <field name="abc_distribution_account_map" column_invisible="1" invisible="1"/>
            </xpath>

            <!-- formulario embebido de invoice_line_ids, si existe -->
            <xpath expr="//field[@name='invoice_line_ids']//form//field[@name='analytic_distribution']" position="after">
                <field name="abc_distribution_account_map" invisible="1"/>
            </xpath>

        </field>
    </record>

</odoo>