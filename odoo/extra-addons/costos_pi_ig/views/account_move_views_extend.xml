<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_analytic_accounts" model="ir.ui.view">
        <field name="name">account.move.form.inherit.analytic.accounts</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Reemplazar el campo line_ids por filtered_line_ids para poder ocultar filas ya cargadas -->
            <xpath expr="//page[@name='aml_tab']//field[@name='line_ids']" position="attributes">
                <attribute name="name">filtered_line_ids</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='analytic_distribution']" position="before">
                <field name="allowed_costos_uso_ids" column_invisible="1"/>
                <field name="costos_uso_id" optional="show" domain="[('id', 'in', allowed_costos_uso_ids)]"/>
            </xpath>
            <!-- Agregar la columna invisible en Lineas de Factura -->
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='analytic_distribution']" position="after">
                <field name="analytic_distribution_accounts" column_invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='filtered_line_ids']/list/field[@name='analytic_distribution']" position="before">
                <field name="allowed_costos_uso_ids" column_invisible="1"/>
                <field name="costos_uso_id" optional="show" domain="[('id', 'in', allowed_costos_uso_ids)]"/>
            </xpath>
            <!-- Agregar la columna invisible en Apuntes Contables -->
            <xpath expr="//field[@name='filtered_line_ids']/list/field[@name='analytic_distribution']" position="after">
                <field name="analytic_distribution_accounts" column_invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>