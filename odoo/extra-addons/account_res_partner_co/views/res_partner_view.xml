			<record id="account.res_partner_action_supplier" model="ir.actions.act_window">
				<field name="context">
					{'res_partner_search_mode': 'supplier', 'default_is_company': True, 'skip_validation': True}
				</field>
			</record>
			

			<record id="account.res_partner_action_customer" model="ir.actions.act_window">
				<field name="context">
					{'search_default_customer': 1,'res_partner_search_mode': 'customer', 'default_is_company': True, 'default_customer_rank': 1, 'skip_validation': True}
				</field>
			</record>

			<record id="contacts.action_contacts" model="ir.actions.act_window">
				<field name="context">
					{'default_is_company': True, 'skip_validation': True}
				</field>
			</record>
				
	
		<record model="ir.ui.view" id="view_partner_property_form_extended_form">
			<field name="name">res.partner.property.form.inherit.extended.form</field>
			<field name="model">res.partner</field>
			<field name="inherit_id" ref="base.view_partner_form"/>
			<field name="arch" type="xml">


			<xpath expr="//field[@name='vat']" position="attributes">
				  <attribute name="invisible">0</attribute>
			</xpath>


			<xpath expr="//span[@name='address_name']/following-sibling::div[contains(@class, 'o_address_format')]/field[@name='street']" position="attributes">
				<attribute name="required">apor_firstname_aportes</attribute>
			</xpath>

			<xpath expr="//span[@name='address_name']/following-sibling::div[contains(@class, 'o_address_format')]/field[@name='city']" position="attributes">
				<attribute name="required">apor_firstname_aportes</attribute>
			</xpath>

			<xpath expr="//span[@name='address_name']/following-sibling::div[contains(@class, 'o_address_format')]/field[@name='state_id']" position="attributes">
				<attribute name="required">apor_firstname_aportes</attribute>
			</xpath>

			<!-- <xpath expr="//span[@name='address_name']/following-sibling::div[contains(@class, 'o_address_format')]/field[@name='zip']" position="attributes"> -->
				<!-- <attribute name="required">1</attribute> -->
			<!-- </xpath> -->

			<xpath expr="//span[@name='address_name']/following-sibling::div[contains(@class, 'o_address_format')]/div[@name='partner_address_country']/field[@name='country_id']" position="attributes">
				<attribute name="required">apor_firstname_aportes</attribute>
			</xpath>
			
			
			<xpath expr="//span[@name='address_name']" position="before">
								<!-- <field name="vat"/> -->
								<field name="ref"  string='Num_id'/>
								<field name="dv" readonly="1"     force_save="1"/>
								<field name="firstname"  required="apor_firstname_aportes"  />
								<field name="middlename" invisible="is_company"/>
								<field name="lastname" invisible="is_company"/>
								<field name="othername" invisible="is_company"/>
			</xpath>






				
			<xpath expr="//notebook/page[last()]" position="after">
				<page name="aport_partner_info" string="Validac Apor/Subs">
					
						<div class="text-muted">
							Obtener información:
						</div>
						

												

						<button
								name="button_aportes_refresh_data"
								type="object"
								class="btn-link w-auto"
								>
								
							<i title="Update data" role="img" aria-label="Update Data"
							   class="fa fa-fw fa-refresh"/>
						</button>
					
						<!-- <button -->
								<!-- name=" button_insert_from_aportes_data" -->
								<!-- type="object" -->
								<!-- class="btn-link w-auto" -->
								<!-- > -->
								
							<!-- <i title="Update data" role="img" aria-label="Update Data" -->
							   <!-- class="fa fa-fw fa-refresh"/> -->
						<!-- </button> -->
						<button
							name="button_insert_from_aportes_data"
							type="object"
							string="Transferir datos"
							class="btn btn-primary"
							icon="fa-exchange"
							invisible="not apor_relation_withafil"
							help="Transferir información desde aportes"
						/>
					
					
						<group name="container_row_2">

							<group name="misc" string="Misc">

								<field name="apor_is_benefic" readonly="1" force_save="1"/>
								<field name="apor_relation_withafil" readonly="1" force_save="1"/>
								<field name="apor_firstname_aportes" readonly="1" force_save="1"/>
								<field name="apor_middlename" readonly="1" force_save="1"/>
								<field name="apor_lastname" readonly="1" force_save="1"/>
								<field name="apor_othername" readonly="1" force_save="1"/>
								<field name="apor_type_doc" readonly="1" force_save="1"/>
								

								<field name="apor_categorias_id" readonly="1" force_save="1"/>
								
								<field name="apor_email" readonly="1" force_save="1"/>
								<field name="apor_address" readonly="1" force_save="1"/>
								<field name="apor_phone" readonly="1" force_save="1"/>
								<field name="apor_num_afil_ppal" readonly="1" force_save="1"/>
								<field name="last_date_report" readonly="1" force_save="1"   options="{'format': 'd MMMM y'}"/>
							</group>
								
						</group>
		
				</page>
			</xpath>



