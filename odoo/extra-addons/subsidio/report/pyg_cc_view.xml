<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record id="wizard_fpa_pyg_cc_view" model="ir.ui.view">
            <field name="name">Ganancias y Pérdidas por Centro de costo</field>
            <field name="model">fpa.pyg.cc.wizard</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Opciones del informe" version="7.0">
                    <label string=""/>
                    <group col="4">
                        <field name="chart_account_id" widget="selection"/>
                        <field invisible="1" name="company_id"/>
                        <field name="account_filter" invisible="True"/>
                    </group>
                    <notebook colspan="4" tabpos="up">
                        <page string="Parametros Principales">
                            <group string="Periodo">
                                <field name="fiscalyear_id"/>
                                <field name="period_id"/>
                            </group>
                        </page>
                        <page string="Parametros Opcionales">
                            <group string="Cuentas" attrs="{'invisible':[('account_filter', '!=', True)]}">
                                <field name="account_ids"/>
                            </group>
                            <group string="Cuenta analitica" >
                                <field name="analytic_ids"/>
                            </group>
                        </page>
                    </notebook>
                    <footer>
                        <button class="oe_highlight" default_focus="1" name="generar" string="Generar" type="object"/>o


                        <button class="oe_link" special="cancel" string="Cancelar"/></footer>
                </form>
            </field>
        </record>

        <record id="action_fpa_pyg_cc" model="ir.actions.act_window">
            <field name="name">Asistente para generar Ganancias y Pérdidas</field>
            <field name="res_model">fpa.pyg.cc.wizard</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="wizard_fpa_pyg_cc_view"/>
            <field name="target">new</field>
        </record>
        <record id="view_fpa_pyg_cc_line_tree" model="ir.ui.view">
            <field name="name">fpa.pyg.cc.line.tree</field>
            <field name="model">fpa.pyg.cc.line</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree default_order="account_id">
                    <field name="account_id"/>
                    <field name="analytic_account_id"/>
                    <field name="amount_ejecutado"/>
                    <field name="amount_presupuestado"/>
                    <field name="amount_ejecutado_ant"/>
                </tree>
            </field>
        </record>
        <record id="action_pyg_cc" model="ir.actions.act_window">
            <field name="name">Ganancias y Pérdidas por Centro de costo</field>
            <field name="res_model">fpa.pyg.cc.line</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,graph</field>
            <field name="view_id" ref="view_fpa_pyg_cc_line_tree"/>
            <field name="domain">[('user_id', '=', uid)]</field>
            <field name="target">current</field>
        </record>
        <!--<menuitem action="action_pyg" id="menu_fpa_pyg" name="Ganancias y Pérdidas" parent="menu_fpa_analyze_financial_reports" sequence="10"/>-->
        <record id="view_fpa_pyg_cc_line_graph" model="ir.ui.view">
            <field name="name">fpa.pyg.line.graph</field>
            <field name="model">fpa.pyg.cc.line</field>
            <field name="type">graph</field>
            <field name="arch" type="xml">
                <graph stacked="True" string="Informe Ganancias y Pérdidas por centro de costo" type="pivot">
                    <!--<field name="amount_inicial" type="measure"/>
                    <field name="debit" type="measure"/>
                    <field name="credit" type="measure"/>-->
                    <field name="amount_ejecutado" type="measure"/>
                </graph>
            </field>
        </record>
        <record id="fpa_pyg_cc_line" model="ir.ui.view">
            <field name="name">fpa.pyg.cc.line.search</field>
            <field name="model">fpa.pyg.cc.line</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="Buscar">
                    <field name="account_id" operator="Cuenta"/>
                    <filter string="Resumen" name="sin_cuenta" icon="terp-personal" domain="[('account_id','=',False)]" />
                    <filter domain="['|',('nivel','=',1),('nivel','=',98)]" name="nivel_1" string="Nivel 1"/>
                    <filter domain="[('nivel','=',2)]" name="nivel_2" string="Nivel 2"/>
                    <filter domain="[('nivel','=',3)]" name="nivel_3" string="Nivel 3"/>
                    <filter domain="[('nivel','=',4)]" name="nivel_4" string="Nivel 4"/>
                    <group expand="0" string="Group By">
                        <filter context="{'group_by':'account_id'}" string="Cuenta"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</openerp>
